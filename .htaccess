# Raggiungibilità dei tornei anche tramite slug (oltre al codice alfanumerico).
# Vedi slug-router.php per i dettagli di come funziona.
#
# Due meccanismi indipendenti, usati insieme per massima compatibilità con
# hosting diversi:
# 1) RewriteRule (mod_rewrite) - si attiva SOLO quando il percorso richiesto
#    non corrisponde a nessuna cartella/file reale, quindi non tocca in alcun
#    modo l'accesso normale tramite codice.
# 2) ErrorDocument 404 - fallback più compatibile, funziona anche se
#    mod_rewrite non è disponibile/consentito in questa cartella: quando
#    Apache genererebbe un 404 qui dentro, serve invece slug-router.php.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /projects/bm/

  # 🆕 Inoltra esplicitamente l'header Authorization (necessario per il
  # login dei pannelli admin dei singoli tornei): su alcune configurazioni,
  # con RewriteEngine attivo, questo header può non arrivare a PHP senza
  # questa regola.
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !^/projects/bm/slug-router\.php
  RewriteRule ^([a-zA-Z0-9\-]+)(/(.*))?$ slug-router.php?slug=$1&path=$3 [L,QSA]
</IfModule>

ErrorDocument 404 /projects/bm/slug-router.php
