# Raggiungibilità dei tornei anche tramite slug (oltre al codice alfanumerico).
# Vedi slug-router.php per i dettagli di come funziona.
#
# Questa regola si attiva SOLO quando il percorso richiesto non corrisponde a
# nessuna cartella o file realmente esistente: l'accesso normale tramite
# codice (.../<codice>/...) continua quindi a funzionare esattamente come
# prima, senza alcuna modifica.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /projects/bm/

  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !^/projects/bm/slug-router\.php
  RewriteRule ^([a-zA-Z0-9\-]+)(/(.*))?$ slug-router.php?slug=$1&path=$3 [L,QSA]
</IfModule>
